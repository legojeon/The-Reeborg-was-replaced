{
  "version": 2,
  "size": {
    "rows": 4,
    "cols": 10
  },
  "robot": {
    "x": 1,
    "y": 1,
    "dir": "E"
  },
  "id": "ato280",
  "name": "ato280",
  "difficulty": 2,
  "description": [
    "A simple, empty world, ready for Reeborg to explore."
  ],
  "goal": {},
  "generated": true,
  "onload": [
    "function shuffle(array) {",
    "    return array.sort(() => Math.random() - 0.5);",
    "}",
    "function randint(min, max) {",
    "    return Math.floor(Math.random() * (max - min + 1)) + min;",
    "};",
    "",
    "let bucket = [2, 3, 4, 5, 6, 7, 8, 9];",
    "// cols에서 랜덤으로 4개 뽑기",
    "bucket = shuffle(bucket).slice(0, 4);",
    "let total = 0;",
    "bucket.forEach(function(num) {",
    "    var cnt = RUR.randint(1, 9);    ",
    "    RUR.add_object('carrot', num, 1, {'number': cnt}) ;",
    "    total += cnt;",
    "});",
    "",
    "for(var x=2; x<10; x++) {",
    "    RUR.add_object('carrot', 10, 1, {'goal': true, 'number': total });}",
    ""
  ]
}
