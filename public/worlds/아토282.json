    "}",
    "",
    "//north",
    "for (var x=2; x<11; x++) {",
    "    var cnt = getRand();",
    "    RUR.add_object('carrot', x, 10, {'number': cnt} );",
    "    RUR.add_object('carrot', x, 10, {'number': 1, 'goal': true} );",
    "}",
    "",
    "// west",
    "for (var y=2; y<11; y++) {",
