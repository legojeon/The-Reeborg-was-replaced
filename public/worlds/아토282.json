    "    RUR.add_object('carrot', x, 1, {'number': 1, 'goal': true} );",
    "}",
    "",
    "// east ",
    "for (var y=2; y<11; y++) {",
    "    var cnt = getRand();",
    "    RUR.add_object('carrot', 10, y, {'number': cnt} );",
